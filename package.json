{
  "name": "domdomdom",
  "version": "0.1.1",
  "description": "DOM-aware JS evaluator. Pipe code via stdin to run against any HTML page (URL, local file, or inline). Lightweight happy-dom alternative to Playwright for non-layout, non-interactive tasks.",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "bin": {
    "domdomdom": "./cli.ts"
  },
  "files": [
    "cli.ts",
    "index.ts",
    "skills/",
    ".claude-plugin/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "quality": "tsc --noEmit && bun test"
  },
  "engines": {
    "node": ">=23.6",
    "bun": ">=1.3"
  },
  "license": "MIT",
  "author": "scruffymongrel",
  "homepage": "https://github.com/scruffymongrel/domdomdom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scruffymongrel/domdomdom.git"
  },
  "bugs": {
    "url": "https://github.com/scruffymongrel/domdomdom/issues"
  },
  "keywords": [
    "dom",
    "happy-dom",
    "html",
    "evaluation",
    "scraping",
    "testing",
    "cli",
    "claude-code",
    "agent-skill"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "happy-dom": "^20.9.0"
  }
}
